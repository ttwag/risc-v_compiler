fn abs ( n : int ) -> int {
    let result : int := 0 ;
    if ( n > 0 ) { result := n ; }
    else { result := 0 - n ; }
    return result ;
}
fn divide ( n : int , m : int ) -> int {
    let quotient : int := 0 ;
    if ( abs ( m ) > abs ( n ) ) { quotient := 0 ; }
    else {
        if ( n > 0 ) {
            if ( m > 0 ) { quotient := divide ( n - m , m ) + 1 ; }
            else { quotient := divide ( n + m , m ) - 1 ; }
        }
        else {
            if ( m > 0 ) { quotient := divide ( n + m , m ) - 1 ; }
            else { quotient := divide ( n - m , m ) + 1 ; }
        }
    }
    return  quotient ;
}
fn main() -> int {
    return divide(1, 0);
}