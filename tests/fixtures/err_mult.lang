fn multiply ( n : int , m : int ) -> int {
    let product : int := 0 ;
    if ( m == 0 ) { product := 0 ; }
    elif ( m > 0 ) {
        if ( n > 0 ) { product := multiply ( n , m - 1 ) + n ; }
        elif ( n == 0 ) { product := 0 ; }
        else { product := multiply ( n , m - 1 ) - n ; }
        }
    else {
        if ( n > 0 ) { product := multiply ( n , m + 1 ) - n ; }
        elif ( n == 0 ) { product := 0 ; }
        else { product := multiply ( n , m + 1 ) + n ; }
    }
    return product ;
}