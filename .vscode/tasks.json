{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Cargo Format",
            "type": "shell",
            "command": "cargo",
            "args": [
                "fmt"
            ],
            "problemMatcher": []
        },
        {
            "label": "Cargo Run",
            "type": "shell",
            "command": "cargo",
            "args": [
                "run"
            ],
            "problemMatcher": [
                "$rustc"
            ],
            "dependsOn": [
                "Cargo Format"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Rust Unit Test",
            "type": "shell",
            "command": "cargo",
            "args": ["test", "--lib"],
            "problemMatcher": ["$rustc"],
            "group": {
                "kind": "test",
                "isDefault": true
            }
        },
        {
            "label": "Rust Integration Test",
            "type": "shell",
            "command": "cargo",
            "args": ["test", "--test", "${fileBasenameNoExtension}"],
            "problemMatcher": ["$rustc"],
            "group": {
                "kind": "test",
                "isDefault": true
            }
        },
        {
            "label": "Rust All Test",
            "type": "shell",
            "command": "cargo",
            "args": ["test"],
            "problemMatcher": ["$rustc"],
            "group": {
                "kind": "test",
                "isDefault": true
            }
        }
    ]
}
